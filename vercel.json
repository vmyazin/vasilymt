{
    "version": 2,
    "builds": [{
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [{
            "src": "/stylesheets/(.*)",
            "dest": "/public/stylesheets/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/javascript/(.*)",
            "dest": "/public/javascript/$1"
        },
        {
            "src": "/videos/(.*)",
            "dest": "/public/videos/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.js"
        }
    ],
    "env": {
        "NODE_ENV": "production",
        "ACTIVE_PROFILE": "professional"
    }
}